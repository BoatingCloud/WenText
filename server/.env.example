# 服务器配置
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# 数据库类型: postgresql | mysql | mongodb
DB_TYPE=postgresql

# PostgreSQL 配置
DATABASE_URL="postgresql://wenyu:wenyu123@localhost:5432/wenyu?schema=public"

# MySQL 配置 (如果选择 MySQL)
# DATABASE_URL="mysql://wenyu:wenyu123@localhost:3306/wenyu"

# MongoDB 配置 (如果选择 MongoDB)
# MONGODB_URL="mongodb://wenyu:wenyu123@localhost:27017/wenyu"

# Redis 配置
# 方式1: 使用完整 URL（推荐）
# REDIS_URL="redis://localhost:6379"
# REDIS_PASSWORD=""

# 方式2: 分别配置主机和端口（留空 REDIS_URL 时生效）
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# JWT 配置
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# 文件上传配置
UPLOAD_MAX_SIZE=104857600
UPLOAD_TEMP_DIR="/tmp/wenyu-uploads"
STORAGE_BASE_PATH="/data/wenyu/storage"
STORAGE_BACKUP_BASE_PATH="/data/wenyu/storage-backup"

# MinIO 对象存储配置
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="wenyu"

# Elasticsearch 配置（可选，留空则使用默认值 http://elasticsearch:9200）
# ELASTICSEARCH_NODE="http://localhost:9200"
ELASTICSEARCH_USERNAME=""
ELASTICSEARCH_PASSWORD=""

# 邮件配置
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@wenyu.com"

# AI 配置 (可选)
AI_ENABLED=false
AI_PROVIDER="openai"
AI_API_KEY=""
AI_MODEL="gpt-4"

# 日志配置
LOG_LEVEL="info"
LOG_DIR="/var/log/wenyu"

# 安全配置
# CORS 允许的源（可选，留空则开发环境自动允许 localhost:5173,5174,3000，生产环境需明确配置）
# 多个源用逗号分隔，例如: CORS_ORIGIN="https://admin.example.com,https://app.example.com"
# CORS_ORIGIN="http://localhost:5173,http://localhost:5174"
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# 加密配置
ENCRYPTION_KEY="your-32-character-encryption-key"
ENCRYPTION_ALGORITHM="aes-256-gcm"

# OnlyOffice 集成配置
ONLYOFFICE_ENABLED=true
# OnlyOffice 服务地址（可选，留空则使用 http://onlyoffice:80）
# ONLYOFFICE_URL="http://localhost:3001"
# OnlyOffice 浏览器访问地址（可选，留空则使用 ONLYOFFICE_URL）
# ONLYOFFICE_SERVICE_URL="http://localhost:3001"
# OnlyOffice 回调服务器地址（可选，留空则自动从请求头获取，Docker 环境默认 http://server:3000）
# ONLYOFFICE_INTERNAL_SERVER_URL="http://localhost:3000"
ONLYOFFICE_JWT_SECRET="viewmatrix"
